# Lambda Non-Sensitive Environment Variables
# ============================================
# Read by deploy-backend.sh and pushed to Lambda on every deploy.
# Safe to commit - NO secrets here.
# Secrets (API keys, DB password) live in AWS Secrets Manager: swavalambi/ai-credentials
#
# To add a new Lambda env var:
#   1. Add it here
#   2. Add ${VAR_NAME} to the update-function-configuration call in deploy-backend.sh
#   3. Run ./deploy-backend.sh

# Secrets Manager
AI_SECRETS_NAME=swavalambi/ai-credentials
USE_LOCAL_CREDENTIALS=false

# Anthropic
USE_ANTHROPIC=true
ANTHROPIC_MODEL_ID=claude-sonnet-4-6

# Bedrock
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# LLM
ENABLE_STREAMING=true

# DynamoDB
DYNAMODB_TABLE=swavalambi_users

# Vector Store
VECTOR_STORE=pgvector
EMBEDDING_PROVIDER=bedrock-titan
EMBEDDING_CACHE_FILE=/tmp/titan_embedding_cache.pkl

# Voice
VOICE_PROVIDER=sarvam
VOICE_FALLBACK_ENABLED=true
VOICE_ENABLE_TRANSLATION=true
VOICE_AUTO_PLAY=true
VOICE_SPEED=1.0
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_TTS_SPEAKER_HI=shubh
SARVAM_TTS_SPEAKER_TE=shubh
SARVAM_TTS_SPEAKER_TA=shubh
SARVAM_TTS_SPEAKER_MR=shubh
SARVAM_TTS_SPEAKER_KN=shubh
SARVAM_TTS_SPEAKER_BN=shubh
SARVAM_TTS_SPEAKER_GU=shubh
SARVAM_TTS_SPEAKER_ML=shubh
SARVAM_TTS_SPEAKER_PA=shubh
SARVAM_TTS_SPEAKER_EN=shubh

# AWS Voice (Polly/Transcribe fallback)
AWS_S3_BUCKET=swavalambi-voice
AWS_TRANSCRIBE_LANGUAGE=hi-IN
AWS_POLLY_VOICE_ID=Aditi
AWS_TRANSLATE_SOURCE_LANG=auto
AWS_TRANSLATE_TARGET_LANG=en

# S3 Profile Pictures
AWS_S3_BUCKET_NAME=swavalambi-profile-pictures

# Vision Upload Limits
VISION_MAX_FILE_SIZE_MB=10
VISION_MAX_UPLOADS_PER_HOUR=5
VISION_MAX_UPLOADS_PER_10MIN=3

# PostgreSQL (non-sensitive parts - password comes from Secrets Manager)
POSTGRES_HOST=swavalambi-schemes-db.caxq488qazpd.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
